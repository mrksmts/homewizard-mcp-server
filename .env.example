# HomeWizard device IP or .local hostname (required)
# Discover with: dns-sd -B _hwenergy._tcp .
HOMEWIZARD_HOST=192.168.1.100

# API version to use: "v1" (HTTP, no auth, must be enabled in app)
# or "v2" (HTTPS, bearer token, always available, P1 firmware >= 2.2.0)
HOMEWIZARD_API_VERSION=v1

# Required only when HOMEWIZARD_API_VERSION=v2.
# Obtain via: npm run get-token
HOMEWIZARD_TOKEN=

# v2 only: verify the device's TLS certificate. Off by default because the
# device ships with a self-signed cert; flip to "true" if you've installed
# the HomeWizard CA on your system.
HOMEWIZARD_VERIFY_TLS=false
